@{
    ViewData["Title"] = "Music2.0 - Nghe Nhạc Việt";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Music2.0 - Ứng dụng nghe nhạc trực tuyến miễn phí. Nghe nhạc Việt Nam mới nhất, BXH Zing Chart, playlist thịnh hành." />
    <title>@ViewData["Title"]</title>
    <link rel="icon" href="~/music.png" type="image/png" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="app-container">
        <!-- ═══ SIDEBAR ═══ -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <img src="~/music.png" alt="Music2.0" />
                <h1>Music2.0</h1>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section-title">Khám phá</div>
                <div class="nav-item active" data-page="home" id="nav-home">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.5 3.247a1 1 0 00-1 0L4 7.577V20h4.5v-6a1 1 0 011-1h5a1 1 0 011 1v6H20V7.577l-7.5-4.33zm-2-1.732a3 3 0 013 0l7.5 4.33a2 2 0 011 1.732V21a1 1 0 01-1 1h-6.5a1 1 0 01-1-1v-6h-3v6a1 1 0 01-1 1H3a1 1 0 01-1-1V7.577a2 2 0 011-1.732l7.5-4.33z"/></svg>
                    </span>
                    Trang chủ
                </div>
                <div class="nav-item" data-page="search" id="nav-search">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M10.533 1.279c-5.18 0-9.407 4.14-9.407 9.279s4.226 9.279 9.407 9.279c2.234 0 4.29-.77 5.907-2.058l4.353 4.353a1 1 0 101.414-1.414l-4.344-4.344a9.157 9.157 0 002.077-5.816c0-5.14-4.226-9.28-9.407-9.28zm-7.407 9.28c0-4.006 3.302-7.28 7.407-7.28s7.407 3.274 7.407 7.28-3.302 7.279-7.407 7.279-7.407-3.273-7.407-7.28z"/></svg>
                    </span>
                    Tìm kiếm
                </div>

                <div class="nav-section-title">Bảng xếp hạng</div>
                <div class="nav-item" data-page="chart" id="nav-chart">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 3v18h18v-2H5V3H3zm14 4a1 1 0 011 1v9a1 1 0 11-2 0V8a1 1 0 011-1zm-4 4a1 1 0 011 1v5a1 1 0 11-2 0v-5a1 1 0 011-1zm-4 2a1 1 0 011 1v3a1 1 0 11-2 0v-3a1 1 0 011-1z"/></svg>
                    </span>
                    #zingchart
                </div>
                <div class="nav-item" data-page="newrelease" id="nav-newrelease">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zm-1 6a1 1 0 112 0v4.586l2.707 2.707a1 1 0 01-1.414 1.414l-3-3A1 1 0 0111 13V8z"/></svg>
                    </span>
                    Nhạc mới
                </div>
                <div class="nav-item" data-page="top100" id="nav-top100">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M5 3a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2H5zm6.5 3.5a1 1 0 112 0V8h1.5a1 1 0 110 2H13.5v1h1a2.5 2.5 0 010 5h-1v.5a1 1 0 11-2 0V16h-1.5a1 1 0 110-2H11.5v-1h-1a2.5 2.5 0 010-5h1V6.5z"/></svg>
                    </span>
                    Top 100
                </div>

                <div class="nav-section-title">Cá nhân</div>
                <div class="nav-item" data-page="library" id="nav-library">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                    </span>
                    Thư viện của tôi
                </div>
            </nav>
        </aside>

        <!-- ═══ MAIN CONTENT ═══ -->
        <main class="main-content" id="main-content">
            <div class="page-content" id="page-content">
                @RenderBody()
            </div>
        </main>

        <!-- ═══ PLAYER BAR ═══ -->
        <div class="player-bar" id="player-bar">
            <!-- Left: Song Info -->
            <div class="player-info">
                <div class="player-thumb" id="player-thumb">
                    <img src="/music.png" alt="" id="player-thumb-img" />
                </div>
                <div class="player-song-info">
                    <div class="player-song-name" id="player-song-name">Chưa phát bài hát nào</div>
                    <div class="player-song-artist" id="player-song-artist">---</div>
                </div>
                <button class="player-like-btn" id="player-like-btn" title="Thêm vào yêu thích">
                    <svg viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                </button>
            </div>

            <!-- Center: Controls -->
            <div class="player-controls">
                <div class="player-buttons">
                    <button class="player-btn" id="btn-shuffle" title="Trộn bài">
                        <svg viewBox="0 0 24 24"><path d="M14.83 13.41l-1.41 1.41 3.13 3.13L14.5 20H20v-5.5l-2.04 2.04-3.13-3.13zM14.83 6.59L20 11.76V6.26h-5.5l2.04 2.04-1.71-1.71zm-4.24 1.82L7.46 5.29 5.29 7.46l3.12 3.12 1.41-1.41-.47-.47.47.47 1.41 1.41-1.41 1.41L4 6.59V6.26h5.5L7.46 8.3l3.13 3.11z"/><path d="M3.5 18.49l7.08-7.08 1.41 1.41-7.08 7.08zM20 18.5l-2.04-2.04-3.13 3.13-1.41-1.41 3.13-3.13-2.05-2.05H20z"/></svg>
                    </button>
                    <button class="player-btn" id="btn-prev" title="Bài trước">
                        <svg viewBox="0 0 24 24"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/></svg>
                    </button>
                    <button class="player-btn btn-play-main" id="btn-play" title="Phát / Tạm dừng">
                        <svg viewBox="0 0 24 24" id="play-icon"><path d="M8 5v14l11-7z"/></svg>
                    </button>
                    <button class="player-btn" id="btn-next" title="Bài tiếp">
                        <svg viewBox="0 0 24 24"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
                    </button>
                    <button class="player-btn" id="btn-repeat" title="Lặp lại">
                        <svg viewBox="0 0 24 24"><path d="M7 7h10v3l4-4-4-4v3H5v6h2V7zm10 10H7v-3l-4 4 4 4v-3h12v-6h-2v4z"/></svg>
                    </button>
                </div>
                <div class="player-progress">
                    <span class="progress-time" id="progress-current">0:00</span>
                    <div class="progress-bar-wrap" id="progress-bar">
                        <div class="progress-bar-fill" id="progress-fill" style="width: 0%"></div>
                    </div>
                    <span class="progress-time" id="progress-duration">0:00</span>
                </div>
            </div>

            <!-- Right: Volume -->
            <div class="player-extra">
                <div class="player-btn" id="btn-lyrics" title="Lời bài hát">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zM6 20V4h7v5h5v11H6zm2-8h8v2H8v-2zm0 4h5v2H8v-2z"/></svg>
                </div>
                <div class="volume-control">
                    <button class="volume-btn" id="volume-btn" title="Âm lượng">
                        <svg viewBox="0 0 24 24" id="volume-icon"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
                    </button>
                    <div class="volume-slider-wrap" id="volume-bar">
                        <div class="volume-slider-fill" id="volume-fill" style="width: 70%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div class="toast" id="toast"></div>

    <!-- Audio Element -->
    <audio id="audio-player" preload="auto"></audio>

    <script src="~/js/library.js"></script>
    <script src="~/js/player.js"></script>
    <script src="~/js/app.js"></script>
</body>
</html>
